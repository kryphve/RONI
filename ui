--[[
    RONI UI Library
    Custom Roblox exploit UI — dark/purple aesthetic
    Mobile + PC supported
--]]

local Library = {}
Library.__index = Library

-- ─────────────────────────────────────────────
--  SERVICES & CONSTANTS
-- ─────────────────────────────────────────────
local TweenService      = game:GetService("TweenService")
local UserInputService  = game:GetService("UserInputService")
local RunService        = game:GetService("RunService")
local Players           = game:GetService("Players")
local CoreGui           = game:GetService("CoreGui")
local HttpService       = game:GetService("HttpService")

local LocalPlayer = Players.LocalPlayer

-- Palette
local C = {
    BG          = Color3.fromRGB(16, 12, 22),
    SIDEBAR     = Color3.fromRGB(22, 16, 32),
    PANEL       = Color3.fromRGB(20, 14, 28),
    BORDER      = Color3.fromRGB(130, 0, 230),
    ACCENT      = Color3.fromRGB(140, 0, 255),
    ACCENT_DIM  = Color3.fromRGB(80, 0, 160),
    ACCENT_DARK = Color3.fromRGB(40, 10, 65),
    TOGGLE_OFF  = Color3.fromRGB(55, 50, 68),
    TEXT        = Color3.fromRGB(235, 230, 245),
    TEXT_DIM    = Color3.fromRGB(160, 150, 175),
    TEXT_SECTION= Color3.fromRGB(200, 180, 230),
    WHITE       = Color3.fromRGB(255, 255, 255),
    BLACK       = Color3.fromRGB(0, 0, 0),
    SHADOW      = Color3.fromRGB(8, 5, 14),
    SUCCESS     = Color3.fromRGB(80, 230, 120),
    WARNING     = Color3.fromRGB(255, 200, 60),
}

local FONT_BOLD    = Enum.Font.GothamBold
local FONT_SEMI    = Enum.Font.GothamSemibold
local FONT_REG     = Enum.Font.Gotham
local SIDEBAR_W    = 160
local WINDOW_W     = 580
local WINDOW_H     = 380
local ITEM_H       = 40
local ITEM_H_TOUCH = 50 -- taller on mobile
local PADDING      = 12
local CORNER       = 10

local IS_MOBILE = UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled

-- ─────────────────────────────────────────────
--  UTILITY
-- ─────────────────────────────────────────────
local function Tween(obj, info, props)
    local t = TweenService:Create(obj, info, props)
    t:Play()
    return t
end

local function MakeCorner(r, parent)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or CORNER)
    c.Parent = parent
    return c
end

local function MakeStroke(thickness, color, parent)
    local s = Instance.new("UIStroke")
    s.Thickness = thickness or 1.5
    s.Color = color or C.BORDER
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = parent
    return s
end

local function MakePadding(top, bottom, left, right, parent)
    local p = Instance.new("UIPadding")
    p.PaddingTop    = UDim.new(0, top    or PADDING)
    p.PaddingBottom = UDim.new(0, bottom or PADDING)
    p.PaddingLeft   = UDim.new(0, left   or PADDING)
    p.PaddingRight  = UDim.new(0, right  or PADDING)
    p.Parent = parent
    return p
end

local function MakeListLayout(spacing, dir, parent)
    local l = Instance.new("UIListLayout")
    l.Padding = UDim.new(0, spacing or 6)
    l.FillDirection = dir or Enum.FillDirection.Vertical
    l.HorizontalAlignment = Enum.HorizontalAlignment.Center
    l.SortOrder = Enum.SortOrder.LayoutOrder
    l.Parent = parent
    return l
end

local function Label(text, size, font, color, parent)
    local l = Instance.new("TextLabel")
    l.Text = text
    l.TextSize = size or 13
    l.Font = font or FONT_REG
    l.TextColor3 = color or C.TEXT
    l.BackgroundTransparency = 1
    l.TextXAlignment = Enum.TextXAlignment.Left
    l.TextTruncate = Enum.TextTruncate.AtEnd
    l.AutomaticSize = Enum.AutomaticSize.None
    l.Parent = parent
    return l
end

local function Frame(color, parent)
    local f = Instance.new("Frame")
    f.BackgroundColor3 = color or C.BG
    f.BorderSizePixel = 0
    f.Parent = parent
    return f
end

local function scrollHeight(list, padding)
    -- Auto-sizes parent ScrollingFrame to fit all children
    if not list or not list.Parent then return end
    RunService.Heartbeat:Wait()
    local h = list.AbsoluteContentSize.Y + (padding or PADDING * 2)
    if list.Parent:IsA("ScrollingFrame") then
        list.Parent.CanvasSize = UDim2.new(0, 0, 0, h)
    end
end

local function readConfig(folder, id)
    local ok, data = pcall(readfile, folder .. "/" .. id .. ".json")
    if ok and data and #data > 0 then
        local ok2, decoded = pcall(function() return HttpService:JSONDecode(data) end)
        if ok2 then return decoded end
    end
    return nil
end

local function writeConfig(folder, id, value)
    pcall(function()
        if not isfolder(folder) then makefolder(folder) end
        writefile(folder .. "/" .. id .. ".json", HttpService:JSONEncode(value))
    end)
end

-- ─────────────────────────────────────────────
--  DRAG (mouse + touch)
-- ─────────────────────────────────────────────
local function MakeDraggable(handle, target)
    local dragging = false
    local startInput, startPos

    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            startInput = input.Position
            startPos = target.Position
        end
    end)

    handle.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and (
            input.UserInputType == Enum.UserInputType.MouseMovement
            or input.UserInputType == Enum.UserInputType.Touch
        ) then
            local delta = input.Position - startInput
            target.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)
end

-- ─────────────────────────────────────────────
--  FLAGS STORE (global toggles / values)
